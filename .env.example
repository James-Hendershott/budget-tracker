# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real secrets.

# Local dev matches docker-compose.yml. In production this points at
# whatever Postgres instance the app is deployed against.
DATABASE_URL="postgresql://budget_tracker:budget_tracker_dev@localhost:5432/budget_tracker?schema=public"

# Only needed for `prisma migrate dev`/`migrate diff` (CLI-time schema
# diffing), never used by the running app. Point it at a scratch database
# on the same Postgres instance.
SHADOW_DATABASE_URL="postgresql://budget_tracker:budget_tracker_dev@localhost:5432/budget_tracker_shadow?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-generated-secret"

# Base URL NextAuth uses for callbacks. Matches your dev server locally;
# set to the real private URL (e.g. Tailscale hostname) in production.
NEXTAUTH_URL="http://localhost:3000"
